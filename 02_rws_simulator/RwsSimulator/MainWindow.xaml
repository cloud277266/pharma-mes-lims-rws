<Window x:Class="RwsSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RwsSimulator.ViewModels"
        mc:Ignorable="d"
        Title="RWS Simulator — 칭량관리시스템"
        Height="720" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- 기본 버튼 스타일 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16"
                Background="#1E3A5F">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="RWS Simulator" FontSize="22" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="칭량관리시스템 — REQ-RWS-001 Hard-lock · REQ-RWS-002 바코드 검증"
                               FontSize="11" Foreground="#93C5FD" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock Text="작업자: " Foreground="#93C5FD" FontSize="13" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding OperatorName, UpdateSourceTrigger=PropertyChanged}"
                             Width="120" FontSize="13" Padding="6,4"
                             Background="#2D4E70" Foreground="White"
                             BorderBrush="#4B7BA8" BorderThickness="1"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 메인 입력 영역 ── -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─ 바코드 스캔 카드 ─ -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="STEP 1 — 바코드 스캔" FontSize="15" FontWeight="Bold"
                               Foreground="#1E3A5F" Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource Label}" Text="원료 바코드 (Enter 또는 버튼으로 스캔)"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource InputBox}"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="15">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="2" Content="스캔"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ScanBarcodeCommand}"/>
                    </Grid>

                    <!-- 샘플 바코드 안내 -->
                    <Border Background="#EFF6FF" CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="테스트 바코드" FontSize="11" FontWeight="Bold"
                                       Foreground="#1D4ED8" Margin="0,0,0,6"/>
                            <ItemsControl FontFamily="Consolas" FontSize="12" Foreground="#1E40AF">
                                <ItemsControl.Items>
                                    <TextBlock Text="BC-RAW-001  → 정제수 500g ±1%"/>
                                    <TextBlock Text="BC-RAW-002  → 유당 100g ±1%"/>
                                    <TextBlock Text="BC-RAW-003  → 전분 50g ±2%"/>
                                    <TextBlock Text="BC-RAW-004  → 스테아르산마그네슘 5g ±5%"/>
                                </ItemsControl.Items>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 바코드 인증 결과 -->
                    <Border Margin="0,12,0,0" Padding="12,8" CornerRadius="6"
                            Visibility="{Binding HasOrder, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F0FDF4"/>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="✔ 바코드 인증 완료" FontWeight="Bold"
                                       Foreground="#15803D" FontSize="13"/>
                            <TextBlock Text="{Binding OrderSummary}" Foreground="#166534"
                                       FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ─ 칭량 입력 카드 ─ -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="STEP 2 — 칭량 입력" FontSize="15" FontWeight="Bold"
                               Foreground="#1E3A5F" Margin="0,0,0,16"/>

                    <!-- 목표 중량 표시 -->
                    <Grid Margin="0,0,0,16" Visibility="{Binding HasOrder, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F9FAFB" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="목표 중량" Style="{StaticResource Label}"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="#111827">
                                    <Run Text="{Binding CurrentOrder.TargetWeight, StringFormat={}{0:F1}}"/>
                                    <Run Text=" g" Foreground="#6B7280" FontSize="14" FontWeight="Normal"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#F9FAFB" CornerRadius="6" Padding="12,8" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="허용 범위" Style="{StaticResource Label}"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#374151">
                                    <Run Text="{Binding CurrentOrder.MinWeight, StringFormat={}{0:F2}}"/>
                                    <Run Text=" ~ "/>
                                    <Run Text="{Binding CurrentOrder.MaxWeight, StringFormat={}{0:F2}}"/>
                                    <Run Text=" g"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 실측값 입력 -->
                    <TextBlock Style="{StaticResource Label}" Text="실측 중량 (g)"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding ActualWeightInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="28" FontWeight="Bold" TextAlignment="Center"
                             IsEnabled="{Binding IsBarcodeVerified}"
                             Foreground="#111827"
                             Margin="0,0,0,12"/>

                    <!-- 오차 상태 표시 -->
                    <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#9CA3AF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWithinTolerance}" Value="True">
                                        <Setter Property="Background" Value="#16A34A"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBarcodeVerified}" Value="True"/>
                                            <Condition Binding="{Binding IsWithinTolerance}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ToleranceStatus}"
                                   FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- 진행률 바 -->
                    <TextBlock Style="{StaticResource Label}" Text="충전율"/>
                    <Border Background="#E5E7EB" CornerRadius="4" Height="12" Margin="0,0,0,16">
                        <Border.Clip>
                            <RectangleGeometry RadiusX="4" RadiusY="4">
                                <RectangleGeometry.Rect>
                                    <Rect Width="940" Height="12"/>
                                </RectangleGeometry.Rect>
                            </RectangleGeometry>
                        </Border.Clip>
                        <Grid>
                            <Rectangle HorizontalAlignment="Left" Height="12" RadiusX="4" RadiusY="4">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Fill" Value="#16A34A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWithinTolerance}" Value="False">
                                                <Setter Property="Fill" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                                <Rectangle.Width>
                                    <MultiBinding>
                                        <MultiBinding.Converter>
                                            <local:RatioToWidthConverter xmlns:local="clr-namespace:RwsSimulator"/>
                                        </MultiBinding.Converter>
                                        <Binding Path="ProgressRatio"/>
                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Rectangle.Width>
                            </Rectangle>
                        </Grid>
                    </Border>

                    <!-- 완료 버튼 -->
                    <Button Content="✔ 칭량 완료 &amp; 라벨 발행"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding CompleteWeighingCommand}"
                            Height="48" FontSize="15"/>

                    <!-- [REQ-RWS-001] 차단 안내 메시지 -->
                    <TextBlock Margin="0,8,0,0" TextAlignment="Center" FontSize="11"
                               Foreground="#DC2626" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBarcodeVerified}" Value="True"/>
                                            <Condition Binding="{Binding IsWithinTolerance}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        ⚠ 허용 오차를 벗어나 완료할 수 없습니다 (REQ-RWS-001)
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── 하단: 상태 메시지 + 완료 이력 ── -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상태 메시지 -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16"
                    Background="#1E3A5F">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14"
                               Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="초기화" HorizontalAlignment="Right"
                            Style="{StaticResource DangerBtn}"
                            Command="{Binding ResetCommand}"
                            Padding="14,6" FontSize="12"/>
                </Grid>
            </Border>

            <!-- 완료 이력 테이블 -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="칭량 완료 이력" FontSize="14" FontWeight="Bold"
                               Foreground="#1E3A5F" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding CompletedRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB"
                              FontSize="13">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="작업 지시 번호" Binding="{Binding OrderId}" Width="140"/>
                            <DataGridTextColumn Header="바코드" Binding="{Binding MaterialBarcode}" Width="110"/>
                            <DataGridTextColumn Header="원료명" Binding="{Binding MaterialName}" Width="*"/>
                            <DataGridTextColumn Header="목표(g)" Binding="{Binding TargetWeight, StringFormat={}{0:F1}}" Width="80"/>
                            <DataGridTextColumn Header="실측(g)" Binding="{Binding ActualWeight, StringFormat={}{0:F3}}" Width="80"/>
                            <DataGridTextColumn Header="작업자" Binding="{Binding Operator}" Width="90"/>
                            <DataGridTextColumn Header="완료 시각" Binding="{Binding CompletedAt, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
